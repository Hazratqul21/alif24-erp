# ===== Database =====
DATABASE_URL=postgresql+asyncpg://erp_user:erp_password@localhost:5432/alif24_erp
ALIF24_DATABASE_URL=postgresql+asyncpg://alif24_user:alif24_password@localhost:5432/alif24

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0

# ===== JWT =====
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== Super Admin =====
SUPER_ADMIN_EMAIL=admin@alif24.uz
SUPER_ADMIN_PASSWORD=change-me

# ===== Eskiz SMS =====
ESKIZ_EMAIL=your@email.com
ESKIZ_PASSWORD=your-eskiz-password
ESKIZ_BASE_URL=https://notify.eskiz.uz/api

# ===== SMTP (Email) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@alif24.uz
SMTP_PASSWORD=change-me
SMTP_FROM=noreply@alif24.uz

# ===== Payment Gateways =====
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=
UZUM_MERCHANT_ID=
UZUM_SECRET_KEY=

# ===== Telegram Bot =====
TELEGRAM_BOT_TOKEN=

# ===== Sentry =====
SENTRY_DSN=

# ===== File Storage =====
UPLOAD_DIR=/data/uploads
MAX_UPLOAD_SIZE_MB=50

# ===== App =====
APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
BASE_DOMAIN=alif24.uz
